# ============================================================
# .env.example — Copy this to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.
# ============================================================

# --- Database credentials (REQUIRED) ------------------------
DB_USER=anomaly
DB_PASSWORD=changeme        # Set a strong password
DB_NAME=anomalydb

# --- Grafana admin password (optional) ----------------------
GF_ADMIN_PASSWORD=admin     # Change before exposing to network

# --- Alerting (optional) ------------------------------------
# Paste your Slack / Teams / Discord / PagerDuty webhook URL.
# Leave blank to disable push alerts.
ALERT_WEBHOOK_URL=

# --- Redis (only needed for local dev outside Docker) --------
# REDIS_HOST=localhost
# REDIS_PORT=6379

# --- Agent (only needed for local dev outside Docker) --------
# TELEMETRY_URL=http://localhost:8080/v1/telemetry
