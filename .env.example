# Environment variable overrides for docker-compose.yml
# Copy this to .env and set your values

# Redis broker address (automatically set by Docker network, leave as-is for compose)
# REDIS_HOST=redis
# REDIS_PORT=6379

# Optional Slack/Teams webhook to receive anomaly alerts
ALERT_WEBHOOK_URL=

# Override Rust agent target (automatically set in Docker Compose)
# TELEMETRY_URL=http://ingestion:8080/v1/telemetry
