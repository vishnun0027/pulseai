{
  "uid": "pulseai-main",
  "title": "PulseAI Monitoring",
  "description": "Real-time anomaly detection, ingestion pipeline, and AI worker metrics for PulseAI.",
  "tags": ["pulseai", "anomaly", "ai"],
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Telemetry Ingestion Rate",
      "description": "Events received per second by the Go ingestion API",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(ingestion_telemetry_received_total[1m])",
          "legendFormat": "received/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(ingestion_telemetry_accepted_total[1m])",
          "legendFormat": "accepted/s",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(ingestion_telemetry_duplicated_total[1m])",
          "legendFormat": "duplicated/s",
          "refId": "C"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Anomaly Detection Rate",
      "description": "Anomalies detected per second by the AI worker",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "reqps"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(ai_anomalies_detected_total[1m])",
          "legendFormat": "anomalies/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(ai_drift_detected_total[1m])",
          "legendFormat": "drift events/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "AI Inference Throughput",
      "description": "Total events processed vs anomalies over time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(ai_inference_processed_total[1m])",
          "legendFormat": "processed/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(ai_model_training_events_total[1m])",
          "legendFormat": "model retrains/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Anomaly Score Distribution (p50/p90/p99)",
      "description": "Anomaly score percentiles over time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(ai_anomaly_score_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.90, rate(ai_anomaly_score_bucket[5m]))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(ai_anomaly_score_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Events Processed",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short",
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "graphMode": "area" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "ai_inference_processed_total",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Anomalies Detected",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "graphMode": "area" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "ai_anomalies_detected_total",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Drift Events",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "graphMode": "area" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "ai_drift_detected_total",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Dedup Cache Size",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 9000 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "ingestion_dedup_cache_size",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ]
}
